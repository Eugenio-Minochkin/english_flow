    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "grammy": "^1.34.0",
    "openai": "^4.76.1",
    "pg-boss": "^10.2.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"

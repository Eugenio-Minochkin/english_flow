NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/english_flow

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
ALLOWED_TELEGRAM_IDS=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

DEEPGRAM_API_KEY=

DEFAULT_TIMEZONE=Asia/Bangkok
QUIET_HOURS_START=22:00
QUIET_HOURS_END=10:00

MAX_AI_CALLS_PER_USER_PER_DAY=80
MAX_VOICE_ATTEMPTS_PER_USER_PER_DAY=50
MAX_AUDIO_DURATION_SECONDS=90

STORE_RAW_AUDIO=false
LOG_LEVEL=info
